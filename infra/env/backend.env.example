# Backend - copier en backend.env et remplir les valeurs
# En prod sur VPS : définir ces variables (systemd, docker, ou .env)

PORT=3000
NODE_ENV=production

# MongoDB (local Docker ou URI Atlas)
MONGO_URI=mongodb://mongo:27017/tp_bigdata

# CORS : URL(s) du frontend, séparées par des virgules si plusieurs
# Ex: https://ton-app.ton-domaine.fr
CORS_ORIGIN=https://ton-frontend.example.com

# Optionnel : clé Unsplash pour le bootstrap d'images (créer une app sur unsplash.com/developers)
# UNSPLASH_ACCESS_KEY=ta_cle_ici

# Entraînement automatique périodique (true/false)
ENABLE_WEB_TRAINING=false
